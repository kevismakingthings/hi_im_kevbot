[gd_resource type="ShaderMaterial" format=3 uid="uid://8ockfqhawrjt"]

[sub_resource type="Shader" id="Shader_ofbwx"]
code = "shader_type canvas_item;

// --- dithered base layer ---
uniform vec4 color_a : source_color = vec4(0.05, 0.05, 0.2, 1.0);
uniform vec4 color_b : source_color = vec4(0.9, 0.5, 0.7, 1.0);
uniform float radius = 0.5;
uniform float falloff = 0.05;
uniform float rings = 3.0;
uniform float speed = 0.15;
uniform float cell_size = 4.0;

// --- smooth hue-shift overlay ---
uniform vec4 color_c : source_color = vec4(0.0, 1.0, 0.83, 1.0);
uniform vec4 color_d : source_color = vec4(1.0, 0.67, 0.0, 1.0);
uniform float rings2 = 2.0;
uniform float speed2 = 0.08;
uniform float shift = 0.5;       // hue-shift strength

uniform float aspect = 1.0;
uniform vec2 center = vec2(0.5);

const float bayer[16] = float[16](
     0.0,  8.0,  2.0, 10.0,
    12.0,  4.0, 14.0,  6.0,
     3.0, 11.0,  1.0,  9.0,
    15.0,  7.0, 13.0,  5.0
);

vec3 rgb2hsv(vec3 c) {
    vec4 K = vec4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);
    vec4 p = mix(vec4(c.bg, K.wz), vec4(c.gb, K.xy), step(c.b, c.g));
    vec4 q = mix(vec4(p.xyw, c.r), vec4(c.r, p.yzx), step(p.x, c.r));
    float d = q.x - min(q.w, q.y);
    float e = 1.0e-10;
    return vec3(abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x);
}

vec3 hsv2rgb(vec3 c) {
    vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
    vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
    return c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
}

void fragment() {
    vec2 pp = floor(FRAGCOORD.xy / cell_size);
    int ix = int(mod(pp.x, 4.0));
    int iy = int(mod(pp.y, 4.0));
    float threshold = (bayer[iy * 4 + ix] + 0.5) / 16.0;

    vec2 d = UV - center;
    d.x *= aspect;
    float dist = length(d);

    // dithered base layer
	float g_base = abs(fract(dist * rings + TIME * speed) * 2.0 - 1.0);
    //float g_base = fract(dist * rings - TIME * speed);
    vec3 base_col = mix(color_a, color_b, step(threshold, g_base)).rgb;

    // smooth overlay — triangle wave so it's seamless (no dither to hide a seam)
    float g_over = abs(fract(dist * rings2 - TIME * speed2) * 2.0 - 1.0);
    vec3 over_col = mix(color_c, color_d, g_over).rgb;

    float mask = 1.0 - smoothstep(radius - falloff, radius, dist);

    // rotate base hue by overlay hue, scaled by overlay saturation + strength
    vec3 bh = rgb2hsv(base_col);
    vec3 oh = rgb2hsv(over_col);
    bh.x = fract(bh.x + oh.x * oh.y * shift);

    COLOR = vec4(hsv2rgb(bh), mask);
}"

[resource]
shader = SubResource("Shader_ofbwx")
shader_parameter/color_a = Color(0.2864527, 0.4851588, 0.61778843, 1)
shader_parameter/color_b = Color(0.4811998, 0.6979834, 0.707908, 1)
shader_parameter/radius = 0.5
shader_parameter/falloff = 1.62
shader_parameter/rings = 2.28
shader_parameter/speed = -0.27
shader_parameter/cell_size = 4.0
shader_parameter/color_c = Color(0.9154002, 0.9597884, 0.42089856, 1)
shader_parameter/color_d = Color(0.9937182, 0.69795007, 0.8049221, 1)
shader_parameter/rings2 = 1.35
shader_parameter/speed2 = 0.02
shader_parameter/shift = -2.54
shader_parameter/aspect = 1.0
shader_parameter/center = Vector2(0.5, 0.5)
